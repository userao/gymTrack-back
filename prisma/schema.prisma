// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  login     String     @unique
  password  String     
  username  String     @unique
  email     String?    @unique
  group     Group[]
  trainings Training[]
}

model Group {
  id                Int        @id @default(autoincrement())
  name              String
  user              User[]
  parentId          Int?
  parent            Group?      @relation("ChildrenGroups", fields: [parentId], references: [id], onDelete: Cascade)
  childrenGroups    Group[]    @relation("ChildrenGroups")
  childrenTemplates Template[]
}

model Template {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int
  parent    Group      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  exercises Exercise[]
}

model Training {
  id     Int      @id @default(autoincrement())
  date   DateTime
  userId Int
  user   User     @relation(fields: [userId], references: [id])
}

model Exercise {
  id             Int           @id @default(autoincrement())
  name           String
  parentId       Int
  parentTemplate Template      @relation(fields: [parentId], references: [id])
  muscleGroup    MuscleGroup[]
}

model MuscleGroup {
  id        Int        @id @default(autoincrement())
  name      String
  exercises Exercise[]
}

