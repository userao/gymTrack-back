// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  login     String     @unique
  password  String
  username  String     @unique
  email     String?    @unique
  group     Group[]
  trainings Training[]
  exercises Exercise[]
}

model Group {
  id                Int        @id @default(autoincrement())
  name              String
  user              User[]
  parentId          Int?
  parent            Group?     @relation("ChildrenGroups", fields: [parentId], references: [id], onDelete: Cascade)
  childrenGroups    Group[]    @relation("ChildrenGroups")
  childrenTemplates Template[]
}

model Template {
  id                Int                @id @default(autoincrement())
  name              String
  parentId          Int
  parent            Group              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  templateExercises TemplateExercise[]
}

model Training {
  id                Int                @id @default(autoincrement())
  date              DateTime
  exercises         Exercise[]
  userId            Int
  user              User               @relation(fields: [userId], references: [id])
  trainingExercises TrainingExercise[]
}

model Exercise {
  id                Int                @id @default(autoincrement())
  name              String
  userId            Int?
  user              User?              @relation(fields: [userId], references: [id])
  muscleGroup       MuscleGroup        @relation(fields: [muscleGroupId], references: [id])
  muscleGroupId     Int
  trainings         Training[]
  templateExercises TemplateExercise[]
  trainingExercises TrainingExercise[]
}

model TemplateExercise {
  template   Template @relation(fields: [templateId], references: [id])
  templateId Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId Int
  sets       Set[]

  @@id([templateId, exerciseId])
}

model TrainingExercise {
  training   Training @relation(fields: [trainingId], references: [id])
  trainingId Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId Int
  sets       Set[]

  @@id([trainingId, exerciseId])
}

model Set {
  id               Int               @id @default(autoincrement())
  weight           Int
  reps             Int
  trainingExercise TrainingExercise? @relation(fields: [trainingId, exerciseId], references: [trainingId, exerciseId])
  trainingId       Int?
  exerciseId       Int?
  templateExercise TemplateExercise? @relation(fields: [templateId, exerciseId], references: [templateId, exerciseId])
  templateId       Int?
}

model MuscleGroup {
  id        Int        @id @default(autoincrement())
  name      String
  exercises Exercise[]
}
